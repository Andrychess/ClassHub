{
  "name": "classhub",
  "version": "1.0.1",
  "description": "ClassHub — локальная сеть учебной группы и раздача материалов",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:publish": "electron-builder --win --publish always",
    "release:patch": "npm version patch -m \"Release %s\"",
    "release:minor": "npm version minor -m \"Release %s\"",
    "release:major": "npm version major -m \"Release %s\""
  },
  "author": "ClassHub",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Andrychess/ClassHub.git"
  },
  "homepage": "https://github.com/Andrychess/ClassHub",
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "express": "^4.21.2"
  },
  "build": {
    "appId": "ru.classhub.app",
    "productName": "ClassHub",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Andrychess",
        "repo": "ClassHub"
      }
    ],
    "files": [
      "electron/**/*",
      "src/**/*",
      "src/assets/**/*",
      "src/capture.html",
      "src/capture.js",
      "src/web/**/*",
      "electron/deviceNames.js",
      "electron/networkScan.js",
      "assets/**/*",
      "package.json"
    ]
  }
}
