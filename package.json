{
  "name": "classhub",
  "version": "1.1.1",
  "description": "ClassHub — локальная сеть учебной группы и раздача материалов",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "predist": "powershell -ExecutionPolicy Bypass -File ./scripts/pre-dist.ps1",
    "dist": "node ./scripts/run-dist.js",
    "dist:publish": "node ./scripts/run-dist.js -- --win --publish always",
    "bump": "node ./scripts/bump-version.js patch",
    "bump:patch": "node ./scripts/bump-version.js patch",
    "bump:minor": "node ./scripts/bump-version.js minor",
    "bump:major": "node ./scripts/bump-version.js major",
    "upload:github": "powershell -ExecutionPolicy Bypass -File ./scripts/upload-release.ps1",
    "release": "powershell -ExecutionPolicy Bypass -File ./scripts/release.ps1",
    "release:continue": "powershell -ExecutionPolicy Bypass -File ./scripts/release.ps1 -SkipBump",
    "release:minor": "powershell -ExecutionPolicy Bypass -File ./scripts/release.ps1 -Bump minor",
    "release:major": "powershell -ExecutionPolicy Bypass -File ./scripts/release.ps1 -Bump major"
  },
  "author": "ClassHub",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Andrychess/ClassHub.git"
  },
  "homepage": "https://github.com/Andrychess/ClassHub",
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "express": "^4.21.2"
  },
  "build": {
    "appId": "ru.classhub.app",
    "productName": "ClassHub",
    "directories": {
      "output": "build-output"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Andrychess",
        "repo": "ClassHub"
      }
    ],
    "files": [
      "electron/**/*",
      "src/**/*",
      "src/assets/**/*",
      "src/capture.html",
      "src/capture.js",
      "src/web/**/*",
      "electron/deviceNames.js",
      "electron/networkScan.js",
      "assets/**/*",
      "package.json"
    ]
  }
}
